generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("owner")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  connections  Connection[]
  notifications Notification[]
}

model Connection {
  id             String   @id @default(cuid())
  userId         String
  provider       String   // facebook, whatsapp, airbnb, booking
  connected      Boolean  @default(false)
  accessToken    String?
  refreshToken   String?
  pageId         String?
  pageName       String?
  expiresAt      DateTime?
  rawJson        String?  // store full token data
  connectedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Client {
  id           String   @id @default(cuid())
  name         String
  email        String?
  phone        String?
  channel      String   @default("web")
  status       String   @default("pending") // pending, classified, accepted, rejected, negotiating, manual
  score        Int?
  scoreLabel   String?  // TOP, NORMAL, RIESGO
  scoreReasons String?  // JSON array of reasons
  step         Int      @default(0)
  profile      String?  // JSON object with dates, guests, budget, purpose
  summary      String?
  isManual     Boolean  @default(false)
  sourceId     String?  // external ID from Facebook/WhatsApp etc
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages Message[]
  bookings Booking[]
}

model Message {
  id        String   @id @default(cuid())
  clientId  String
  role      String   // user, assistant, owner
  content   String
  sourceId  String?
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Booking {
  id         String    @id @default(cuid())
  clientId   String?
  propertyId String?
  title      String
  startDate  String
  endDate    String
  notes      String?
  status     String    @default("confirmed") // confirmed, cancelled, pending
  price      Float?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  client   Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  property Property? @relation("PropertyCalendarBookings", fields: [propertyId], references: [id], onDelete: SetNull)
}

model Property {
  id            String   @id @default(cuid())
  name          String
  address       String?
  city          String?
  country       String   @default("España")
  type          String   @default("apartment") // apartment, house, villa, studio, room
  bedrooms      Int      @default(1)
  bathrooms     Int      @default(1)
  guests        Int      @default(2)
  pricePerNight Float    @default(50)
  currency      String   @default("EUR")
  description   String?
  amenities     String?  // JSON array
  images        String?  // JSON array of image URLs
  status        String   @default("active") // active, inactive, maintenance
  petsAllowed       Boolean   @default(false)
  minimumStay       Int       @default(1)
  depositAmount     Float?    // Security deposit
  cleaningFee       Float?    // One-time cleaning fee
  extraGuestFee     Float?    // Fee per extra guest above base
  checkInTime       String?   // e.g. "15:00"
  checkOutTime      String?   // e.g. "11:00"
  cancellationPolicy String?  // flexible, moderate, strict
  houseRules        String?   // Free text rules for guests
  facebookPostId    String?
  facebookPublishedAt DateTime?
  rating            Float?
  totalBookings Int      @default(0)
  totalRevenue  Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookings         PropertyBooking[]
  calendarBookings Booking[]         @relation("PropertyCalendarBookings")
}

model AIConfig {
  id              String   @id @default(cuid())
  ownerName       String   @default("el asistente virtual")
  systemPrompt    String?
  greetingMessage String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model PropertyBooking {
  id         String   @id @default(cuid())
  propertyId String
  clientId   String?
  guestName  String
  startDate  String
  endDate    String
  status     String   @default("confirmed") // confirmed, pending, cancelled, completed
  totalPrice Float?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // message, booking, client, system, alert
  title     String
  content   String?
  read      Boolean  @default(false)
  link      String?  // internal navigation link
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  type      String   // client_created, message_sent, booking_created, action_taken, etc.
  title     String
  content   String?
  metadata  String?  // JSON
  createdAt DateTime @default(now())
}
