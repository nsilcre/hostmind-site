# ── Base de datos ─────────────────────────────────────────────────────────────
# SQLite (desarrollo local):
DATABASE_URL="file:./dev.db"

# PostgreSQL (producción recomendada — Neon, Supabase, Railway):
# DATABASE_URL="postgresql://user:password@host:5432/hostmind?sslmode=require"

# ── Autenticación ─────────────────────────────────────────────────────────────
# Secreto para firmar los JWT. Genera uno seguro con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
AUTH_SECRET="CAMBIA_ESTO_POR_UN_SECRETO_SEGURO_DE_64_CHARS"

# ── IA (Groq) ─────────────────────────────────────────────────────────────────
# Obtén tu clave en: https://console.groq.com/
GROQ_API_KEY=""

# ── Facebook ──────────────────────────────────────────────────────────────────
# Token de verificación del webhook (cualquier string aleatorio, configúralo
# también en Meta Developer Portal → Webhooks → Verify Token)
FACEBOOK_WEBHOOK_VERIFY_TOKEN="hostmind_webhook_token"
